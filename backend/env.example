# Optional: point the frontend at a specific backend URL.
# Leave this unset during development — the Vite dev proxy (vite.config.js)
# forwards /api requests to http://127.0.0.1:5000 automatically.
#
# Set this only if your backend runs somewhere else (e.g. in production):
# VITE_API_BASE=https://your-backend.example.com/api
